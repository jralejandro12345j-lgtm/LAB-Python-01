  saldo = float(input("Ingrese saldo inicial: "))
deposito = float(input("Ingrese deposito: "))
retiro = float(input("Ingrese retiro: "))

saldo = saldo + deposito
saldo = saldo - retiro

interes = 0.02
saldo_final = saldo * (1 + interes)

print(f"Saldo final con interés: ${saldo_final:.2f}")
  
  Estado inicial: valores antes de ejecutar el programa.
Estado final: resultado después de aplicar operaciones.

Cada instrucción modifica la memoria:
- Se actualiza saldo con depósito
- Luego se resta retiro
- Se calcula saldo_final
  temperaturas = [22.5, 23.0, 21.8, 24.3, 25.1]

temperaturas.append(23.7)
temperaturas.pop(0)
temperaturas.insert(1, 22.9)

ordenadas = sorted(temperaturas)
diferencia = max(temperaturas) - min(temperaturas)
promedio = sum(temperaturas) / len(temperaturas)
indice = temperaturas.index(23.7)

print(temperaturas)
print("Ordenadas:", ordenadas)
print("Diferencia:", diferencia)
print("Promedio:", promedio)
print("Índice:", indice)
print("Rango:", temperaturas[1:4])
print("Primeras:", temperaturas[:3])
  inventario = [
    {"nombre": "Pan", "precio": 1500, "stock": 30},
    {"nombre": "Leche", "precio": 3500, "stock": 15},
    {"nombre": "Café", "precio": 8000, "stock": 10},
]

print(inventario[0]["nombre"])

inventario.append({"nombre": "Huevos", "precio": 12000, "stock": 20})

for p in inventario:
    if p["nombre"] == "Leche":
        p["stock"] -= 2

total = sum(p["precio"] * p["stock"] for p in inventario)
print("Total:", total)

for p in inventario:
    if p["stock"] < 10:
        print(p)

for p in inventario:
    p["precio"] = round(p["precio"] * 1.1, 2)

nombre = input("Buscar producto: ")
encontrado = None

for p in inventario:
    if p["nombre"].lower() == nombre.lower():
        encontrado = p

print(encontrado if encontrado else "No encontrado")

inventario = [p for p in inventario if p["stock"] > 0]

inventario.sort(key=lambda x: x["precio"])
print(inventario)
