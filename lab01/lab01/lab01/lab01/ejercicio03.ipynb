import requests

nombre = input("Pokemon: ").lower()

url = f"https://pokeapi.co/api/v2/pokemon/{nombre}"
r = requests.get(url)

if r.status_code == 200:
    datos = r.json()

    tipos = [t["type"]["name"] for t in datos["types"]]
    habilidades = [h["ability"]["name"] for h in datos["abilities"]]

    print("Nombre:", datos["name"])

    if len(tipos) > 1:
        print("Pokemon de tipo mixto")

    if datos["weight"] > 100:
        print("Pokemon de gran tamaño")
    else:
        print("Pokemon ligero")

    print("Habilidades:")
    for h in habilidades:
        print("-", h)

else:
    print("No encontrado")
